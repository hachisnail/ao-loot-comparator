---
// src/pages/records.astro
import MainLayout from "../layouts/MainLayout.astro";
import RecordsViewer from "../components/RecordsViewer.jsx";
---

<MainLayout 
    title="Past Records | AO Loot Logs" 
    description="View and filter previously saved Albion Online loot comparisons from Google Drive."
>
	<div class="max-w-6xl mx-auto px-4 py-10 w-full flex flex-col gap-6">
		
        <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 border-b border-stone-800 pb-4 mb-4">
			<div>
				<h1 class="text-2xl font-bold text-stone-100 uppercase tracking-widest">Historical Records</h1>
				<p class="text-stone-500 mt-1 text-sm tracking-wide uppercase">
					Access saved ledger data directly from your Google Drive.
				</p>
			</div>
		</div>

        <RecordsViewer client:load />

	</div>
</MainLayout>